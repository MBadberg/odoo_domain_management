<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ══ Groups ══════════════════════════════════════════════════════ -->

        <record id="group_domain_manager" model="res.groups">
            <field name="name">Domain Manager</field>
            <field name="category_id" ref="base.module_category_website"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- ══ Record rules ════════════════════════════════════════════════ -->

        <!-- Portal users can only see their own domain orders -->
        <record id="rule_domain_order_portal" model="ir.rule">
            <field name="name">Domain Order: Portal users see only their own</field>
            <field name="model_id" ref="model_domain_order"/>
            <field name="domain_force">[('partner_id', '=', user.partner_id.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Portal users can only see their own domain assets -->
        <record id="rule_domain_asset_portal" model="ir.rule">
            <field name="name">Domain Asset: Portal users see only their own</field>
            <field name="model_id" ref="model_domain_asset"/>
            <field name="domain_force">[('partner_id', '=', user.partner_id.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Internal users see all records (no restriction needed beyond model access) -->

    </data>
</odoo>
