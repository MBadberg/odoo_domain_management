<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══ Actions ══════════════════════════════════════════════════════════ -->

    <record id="action_domain_order" model="ir.actions.act_window">
        <field name="name">Domain Orders</field>
        <field name="res_model">domain.order</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_state': 'draft'}</field>
    </record>

    <!-- ══ List view ════════════════════════════════════════════════════════ -->

    <record id="view_domain_order_list" model="ir.ui.view">
        <field name="name">domain.order.list</field>
        <field name="model">domain.order</field>
        <field name="arch" type="xml">
            <list string="Domain Orders" decoration-success="state == 'registered'"
                  decoration-danger="state == 'failed'"
                  decoration-muted="state == 'cancelled'">
                <field name="name"/>
                <field name="tld"/>
                <field name="partner_id"/>
                <field name="period"/>
                <field name="availability"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'registered'"
                       decoration-warning="state == 'pending'"
                       decoration-danger="state == 'failed'"/>
                <field name="date_order"/>
                <field name="date_registered"/>
            </list>
        </field>
    </record>

    <!-- ══ Form view ════════════════════════════════════════════════════════ -->

    <record id="view_domain_order_form" model="ir.ui.view">
        <field name="name">domain.order.form</field>
        <field name="model">domain.order</field>
        <field name="arch" type="xml">
            <form string="Domain Order">
                <header>
                    <button name="action_check_availability" type="object"
                            string="Check Availability"
                            class="btn-secondary"
                            invisible="state not in ['draft']"/>
                    <button name="action_purchase" type="object"
                            string="Register Domain"
                            class="btn-primary"
                            invisible="availability != 'available' or state not in ['availability_checked']"/>
                    <button name="action_sync_status" type="object"
                            string="Sync Status"
                            class="btn-secondary"
                            invisible="state != 'registered'"/>
                    <button name="action_cancel" type="object"
                            string="Cancel"
                            class="btn-secondary"
                            invisible="state in ['registered', 'cancelled']"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,availability_checked,pending,registered"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="e.g. example.de"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Domain">
                            <field name="tld"/>
                            <field name="period"/>
                            <field name="availability"/>
                            <field name="date_order"/>
                            <field name="date_registered"/>
                        </group>
                        <group string="Customer">
                            <field name="partner_id"/>
                            <field name="user_id"/>
                            <field name="asset_id"/>
                        </group>
                    </group>
                    <separator string="Nameservers"/>
                    <group>
                        <field name="nameserver0"/>
                        <field name="nameserver1"/>
                    </group>
                    <separator string="Contact Handles (Domainrobot)"/>
                    <group>
                        <field name="owner_contact"/>
                        <field name="admin_contact"/>
                        <field name="tech_contact"/>
                        <field name="billing_contact"/>
                    </group>
                    <separator string="API Response"/>
                    <group>
                        <field name="api_response_code"/>
                        <field name="api_response_message"/>
                        <field name="external_order_id"/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- ══ Search view ══════════════════════════════════════════════════════ -->

    <record id="view_domain_order_search" model="ir.ui.view">
        <field name="name">domain.order.search</field>
        <field name="model">domain.order</field>
        <field name="arch" type="xml">
            <search string="Search Domain Orders">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="state"/>
                <field name="availability"/>
                <filter string="Available" name="available"
                        domain="[('availability', '=', 'available')]"/>
                <filter string="Registered" name="registered"
                        domain="[('state', '=', 'registered')]"/>
                <filter string="Failed" name="failed"
                        domain="[('state', '=', 'failed')]"/>
                <filter string="Group by Status" name="group_state"
                        context="{'group_by': 'state'}"/>
                <filter string="Group by TLD" name="group_tld"
                        context="{'group_by': 'tld'}"/>
                <filter string="Group by Customer" name="group_partner"
                        context="{'group_by': 'partner_id'}"/>
            </search>
        </field>
    </record>

    <!-- ══ Menu ═════════════════════════════════════════════════════════════ -->

    <menuitem id="menu_domain_root" name="Domains" sequence="50"/>

    <menuitem id="menu_domain_orders" name="Domain Orders"
              parent="menu_domain_root"
              action="action_domain_order"
              sequence="10"/>

</odoo>
