<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.domain</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app string="Domain Management" name="odoo_domain_management">
                    <block title="Domainrobot API">
                        <setting id="domainrobot_api_url_setting" string="API Endpoint URL"
                                 help="Base URL for the Domainrobot API (sandbox and production use the same URL; credentials differ).">
                            <field name="domainrobot_api_url"
                                   placeholder="https://api.domainreselling.de/api/call.cgi"/>
                        </setting>
                        <setting id="domainrobot_api_user_setting" string="API Username (s_login)">
                            <field name="domainrobot_api_user" placeholder="s_login"/>
                        </setting>
                        <setting id="domainrobot_api_password_setting" string="API Password (s_pw)">
                            <field name="domainrobot_api_password" placeholder="s_pw"/>
                        </setting>
                        <setting id="domainrobot_api_timeout_setting" string="API Timeout (seconds)">
                            <field name="domainrobot_api_timeout"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>

</odoo>
